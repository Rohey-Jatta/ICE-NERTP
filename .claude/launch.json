{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Docs",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8099"],
      "port": 8099
    },
    {
      "name": "Laravel Dev Server",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve"],
      "port": 8000
    },
    {
      "name": "Vite (React + HMR)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Queue Worker",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:listen", "--tries=1", "--timeout=0"],
      "port": 0
    },
    {
      "name": "Laravel Pail (Log Viewer)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "pail", "--timeout=0"],
      "port": 0
    },
    {
      "name": "Docker (PostgreSQL + Redis)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d", "postgres", "redis"],
      "port": 5432
    }
  ]
}
